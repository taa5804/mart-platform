<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>우리APT 차주 최초 등록</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background-color: #f5f7fa; padding: 20px; box-sizing: border-box; }
    .card { background: white; padding: 30px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; max-width: 400px; width: 100%; box-sizing: border-box; }
    h1 { font-size: 22px; color: #1a202c; margin-bottom: 8px; }
    p { font-size: 14px; color: #718096; margin-bottom: 24px; line-height: 1.5; }
    input { width: 100%; padding: 14px; border: 1px solid #cbd5e0; border-radius: 10px; font-size: 16px; margin-bottom: 16px; box-sizing: border-box; text-align: center; }
    button { width: 100%; padding: 14px; border: none; border-radius: 10px; font-size: 16px; font-weight: bold; cursor: pointer; transition: all 0.2s; background-color: #38a169; color: white; }
    button:disabled { background-color: #cbd5e0; color: #718096; cursor: not-allowed; }
    #registerResult { margin-top: 16px; font-size: 14px; font-weight: 500; min-height: 20px; line-height: 1.4; }
  </style>
  <script src="https://jsdelivr.net"></script>
</head>
<body>

  <div class="card">
    <h1>⚙️ 차주 최초 등록</h1>
    <p>안내판의 QR 코드를 활성화하기 위해<br>연락처 등록 및 푸시 알림 수신을 허용해 주세요.</p>
    
    <!-- 차주 등록 정보 입력 폼 -->
    <input type="tel" id="ownerPhoneInput" placeholder="휴대전화 번호 입력 (숫자만)" maxlength="11">
    <button id="registerButton">차량 QR 등록 완료하기</button>
    
    <div id="registerResult"></div>
  </div>

  <script type="module">
    const supabaseUrl=window.location.origin.includes("localhost")?"":Deno.env.get("SUPABASE_URL");const supabaseKey=window.location.origin.includes("localhost")?"":Deno.env.get("SUPABASE_ANON_KEY");const db=supabase.createClient(supabaseUrl||"https://supabase.co",supabaseKey||"your-anon-key");const urlParams=new URLSearchParams(window.location.search);const rawQr=urlParams.get("qr")||window.location.pathname.split("/").pop()?.replace(".html","")||"";const qrCode=String(rawQr).trim().toUpperCase().replace(/[^A-Z0-9_-]/g,"");async function requestNotificationPermission(){try{const permission=await Notification.requestPermission();if(permission!=="granted"){alert("알림 권한이 거부되었습니다. 브라우저 설정에서 알림을 허용해야 호출 푸시를 받으실 수 있습니다.");return null}if("serviceWorker"in navigator){const reg=await navigator.serviceWorker.register("/firebase-messaging-sw.js").catch(()=>null);if(reg&&"pushManager"in reg){const subscription=await reg.pushManager.getSubscription()||await reg.pushManager.subscribe({userVisibleOnly:true,applicationServerKey:"YOUR_VAPID_PUBLIC_KEY"});if(subscription){return btoa(JSON.stringify(subscription))}}}return"mock_push_token_for_test"}catch(e){console.error(e);return"mock_push_token_for_test"}}async function handleRegistration(){const phoneInput=document.getElementById("ownerPhoneInput");const regButton=document.getElementById("registerButton");const resultMsg=document.getElementById("registerResult");const phone=String(phoneInput?.value||"").replace(/[^0-9]/g,"");if(!phone||phone.length<10){alert("올바른 휴대전화 번호를 입력해 주세요.");return}if(!qrCode){alert("QR 코드 정보가 인식되지 않았습니다.");return}regButton.disabled=true;regButton.textContent="등록 처리 중...";resultMsg.textContent="";const pushToken=await requestNotificationPermission();if(!pushToken){resultMsg.style.color="red";resultMsg.textContent="오류: 알림 권한 허용이 필요합니다.";regButton.disabled=false;regButton.textContent="차량 QR 등록 완료하기";return}try{const{data,error}=await db.functions.invoke("send-vehicle-push",{body:{action:"register",qr_code:qrCode,owner_phone:phone,push_token:pushToken}});if(error)throw new Error(error.message);if(data&&data.ok===false)throw new Error(data.message||"등록에 실패했습니다.");resultMsg.style.color="green";resultMsg.textContent="🎉 차량 QR 등록이 성공적으로 완료되었습니다! 이제 차량 이동 알림을 받으실 수 있습니다.";phoneInput.disabled=true}catch(err){console.error("등록 실패:",err);resultMsg.style.color="red";resultMsg.textContent="등록 실패: "+(err.message||"알 수 없는 오류");regButton.disabled=false;regButton.textContent="차량 QR 등록 완료하기"}}document.addEventListener("DOMContentLoaded",()=>{document.getElementById("registerButton")?.addEventListener("click",handleRegistration)});
  </script>
</body>
</html>
