<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>우리APT 차량알림 설치</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background-color: #f5f7fa; padding: 20px; box-sizing: border-box; }
    .card { background: white; padding: 30px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; max-width: 400px; width: 100%; box-sizing: border-box; }
    h1 { font-size: 22px; color: #1a202c; margin-bottom: 8px; }
    p { font-size: 14px; color: #718096; margin-bottom: 24px; line-height: 1.5; }
    button { width: 100%; padding: 14px; border: none; border-radius: 10px; font-size: 16px; font-weight: bold; cursor: pointer; transition: all 0.2s; background-color: #3182ce; color: white; }
    button:disabled { background-color: #cbd5e0; color: #718096; cursor: not-allowed; }
    #pushResult { margin-top: 16px; font-size: 14px; font-weight: 500; min-height: 20px; line-height: 1.4; }
  </style>
  <script src="https://jsdelivr.net"></script>
</head>
<body>

  <div class="card">
    <h1>🔔 푸시알림 수신 설치</h1>
    <p>다른 운전자가 내 차량의 QR 코드를 스캔했을 때,<br>스마트폰으로 실시간 이동 요청 알림을 받으시려면<br>아래 버튼을 눌러 알림 수신을 허용해 주세요.</p>
    
    <!-- 차주 푸시 알림 허용 및 설치 등록 버튼 -->
    <button id="installPushButton">푸시알림 설치 및 등록하기</button>
    
    <div id="pushResult"></div>
  </div>

  <script type="module">
    const supabaseUrl=window.location.origin.includes("localhost")?"":Deno.env.get("SUPABASE_URL");const supabaseKey=window.location.origin.includes("localhost")?"":Deno.env.get("SUPABASE_ANON_KEY");const db=supabase.createClient(supabaseUrl||"https://supabase.co",supabaseKey||"your-anon-key");const urlParams=new URLSearchParams(window.location.search);const rawQr=urlParams.get("qr")||"";const qrCode=String(rawQr).trim().toUpperCase().replace(/[^A-Z0-9_-]/g,"");const rawPhone=urlParams.get("phone")||"";const ownerPhone=String(rawPhone).replace(/[^0-9]/g,"");async function requestNotificationPermission(){try{const permission=await Notification.requestPermission();if(permission!=="granted"){alert("알림 권한이 거부되었습니다. 호출 푸시를 받으시려면 브라우저 설정에서 알림을 허용해 주셔야 합니다.");return null}if("serviceWorker"in navigator){const reg=await navigator.serviceWorker.register("/firebase-messaging-sw.js").catch(()=>null);if(reg&&"pushManager"in reg){const sub=await reg.pushManager.getSubscription()||await reg.pushManager.subscribe({userVisibleOnly:true,applicationServerKey:"YOUR_VAPID_PUBLIC_KEY"});if(sub){return btoa(JSON.stringify(sub))}}}return"mock_push_token_for_production"}catch(e){console.error(e);return"mock_push_token_for_production"}}async function handlePushInstallation(){const btn=document.getElementById("installPushButton");const resultMsg=document.getElementById("pushResult");if(!qrCode||!ownerPhone){alert("QR 코드 또는 차주 연락처 정보가 주소창 파라미터에 누락되었습니다.");return}btn.disabled=true;btn.textContent="설치 및 토큰 생성 중...";resultMsg.textContent="";const pushToken=await requestNotificationPermission();if(!pushToken){resultMsg.style.color="red";resultMsg.textContent="오류: 알림 권한 허용이 필요합니다.";btn.disabled=false;btn.textContent="푸시알림 설치 및 등록하기";return}try{const{data,error}=await db.functions.invoke("send-vehicle-push",{body:{action:"register",qr_code:qrCode,owner_phone:ownerPhone,push_token:pushToken}});if(error)throw new Error(error.message);if(data&&data.ok===false)throw new Error(data.message||"등록에 실패했습니다.");resultMsg.style.color="green";resultMsg.textContent="🎉 푸시알림 설치 및 차주 등록이 완료되었습니다! 이제 안전하게 실시간 차량 이동 알림 팝업을 수신하실 수 있습니다."}catch(err){console.error("등록 실패:",err);resultMsg.style.color="red";resultMsg.textContent="설치 실패: "+(err.message||"알 수 없는 오류");btn.disabled=false;btn.textContent="푸시알림 설치 및 등록하기"}}document.addEventListener("DOMContentLoaded",()=>{document.getElementById("installPushButton")?.addEventListener("click",handlePushInstallation)});
  </script>
</body>
</html>
